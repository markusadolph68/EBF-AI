WEBUI_NAME="EBF AI"
WEBUI_SECRET_KEY=change-me-before-sharing
WEBUI_URL=http://localhost:3000
DEFAULT_LOCALE=de-DE
OPEN_WEBUI_PORT=3000
ENABLE_SIGNUP=true
ENABLE_PERSISTENT_CONFIG=False

ENABLE_OLLAMA_API=False
ENABLE_OPENAI_API=True
OPENAI_API_BASE_URL=http://host.docker.internal:8000/v1
OPENAI_API_BASE_URLS=http://host.docker.internal:8000/v1
OPENAI_API_KEY=mlx
TASK_MODEL_EXTERNAL=NexVeridian/Qwen3.5-4B-5bit

VECTOR_DB=chroma
CHROMA_HTTP_HOST=chroma
CHROMA_HTTP_PORT=8000
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

CHROMA_HOST=127.0.0.1
CHROMA_PORT=8001
CHROMA_COLLECTION_PREFIX=ebf_docs
EMBEDDING_MODEL=intfloat/multilingual-e5-small

DEFAULT_CHUNK_SIZE=350
DEFAULT_CHUNK_OVERLAP=50

MLX_HOST=0.0.0.0
MLX_PORT=8000
MLX_MODEL_NAME=NexVeridian/Qwen3.5-4B-5bit
