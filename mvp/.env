APP_NAME=EBF AI MVP
APP_SECRET_KEY=ebf-ai-mvp-dev-secret
APP_HOST=0.0.0.0
APP_PORT=8080

SQLITE_PATH=/data/app.db

CHROMA_HOST=chroma
